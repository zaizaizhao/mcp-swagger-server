{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug MSS - Help",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/packages/mcp-swagger-server/dist/cli-interactive.js",
      "args": ["--help"],
      "cwd": "${workspaceFolder}/packages/mcp-swagger-server",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/packages/mcp-swagger-server/dist/**/*.js"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug MSS - Petstore Streamable",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/packages/mcp-swagger-server/dist/cli-interactive.js",
      "args": [
        "--transport", "streamable",
        "--port", "3323",
        "--openapi", "https://petstore3.swagger.io/api/v3/openapi.json"
      ],
      "cwd": "${workspaceFolder}/packages/mcp-swagger-server",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/packages/mcp-swagger-server/dist/**/*.js"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug MSS - Custom Args",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/packages/mcp-swagger-server/dist/cli-interactive.js",
      "args": [],
      "cwd": "${workspaceFolder}/packages/mcp-swagger-server",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/packages/mcp-swagger-server/dist/**/*.js"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Alias CLI - Petstore Streamable",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/packages/mcp-swagger-server/dist/cli.js",
      "args": [
        "--transport", "streamable",
        "--port", "3323",
        "--openapi", "https://petstore3.swagger.io/api/v3/openapi.json"
      ],
      "cwd": "${workspaceFolder}/packages/mcp-swagger-server",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/packages/mcp-swagger-server/dist/**/*.js"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
