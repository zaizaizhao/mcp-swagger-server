MCP_PORT=3322
MCP_TRANSPORT=stdio
MCP_OPENAPI_URL=https://petstore.swagger.io/v2/swagger.json
MCP_AUTO_RELOAD=false

MCP_AUTH_TYPE=bearer
API_TOKEN=your-bearer-token-here

# CUSTOM_TOKEN=your-custom-token-here
# Use with: --bearer-env CUSTOM_TOKEN

MCP_AUTO_RESTART=true
MCP_MAX_RETRIES=5
MCP_RETRY_DELAY=5000

# Optional API runtime database configuration
# The managed MCP server package itself does not require PostgreSQL.
# These values are relevant when the API package runs in the same environment.
DB_TYPE=sqlite
DB_SQLITE_PATH=data/mcp-swagger.db

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=mcp_swagger_api
