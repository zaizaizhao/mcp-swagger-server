{
  "name": "mcp-swagger-server",
  "version": "1.6.0",
  "description": "A Model Context Protocol (MCP) server for Swagger/OpenAPI documentation that transforms OpenAPI specifications into MCP format, enabling AI assistants to interact with REST APIs through standardized protocol.",
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "bin": {
    "mcp-swagger-server": "./dist/cli.js",
    "mcp-swagger": "./dist/cli.js",
    "mss": "./dist/cli-interactive.js"
  },
  "scripts": {
    "test": "pnpm run build && node scripts/cli-smoke.js && node scripts/smoke-test.js",
    "test:smoke": "pnpm run build && node scripts/smoke-test.js",
    "test:cli": "pnpm run build && node scripts/cli-smoke.js",
    "build": "tsc",
    "dev": "nodemon --exec ts-node src/index.ts --transport streamable --port 3322",
    "start": "node dist/index.js",
    "start:sse": "node dist/index.js --transport sse --port 3322",
    "start:stdio": "node dist/index.js --transport stdio",
    "start:streamable": "node dist/index.js --transport streamable --port 3322",
    "start:cli": "pnpm run cli",
    "cli": "pnpm run build && node dist/cli.js",
    "cli:help": "pnpm run cli -- --help",
    "cli:petstore": "pnpm run cli -- -t streamable -p 3323 -o https://petstore.swagger.io/v2/swagger.json",
    "manager": "ts-node src/tools/mcp-manager.ts",
    "manager:start": "ts-node src/tools/mcp-manager.ts start",
    "manager:stop": "ts-node src/tools/mcp-manager.ts stop",
    "manager:restart": "ts-node src/tools/mcp-manager.ts restart",
    "manager:status": "ts-node src/tools/mcp-manager.ts status",
    "manager:logs": "ts-node src/tools/mcp-manager.ts logs",
    "cli:interactive": "pnpm run build && node dist/cli-interactive.js",
    "cli:interactive:dev": "nodemon --exec \"pnpm run cli:interactive\"",
    "cli:interactive:auto": "pnpm run cli:interactive -- --openapi https://api.example.com/openapi.json --operation-filter-parameters 'userId,email' --transport streamable"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "swagger",
    "openapi",
    "api",
    "rest",
    "ai",
    "assistant",
    "converter",
    "bridge"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zaizaizhao/mcp-swagger-server.git"
  },
  "bugs": {
    "url": "https://github.com/zaizaizhao/mcp-swagger-server/issues"
  },
  "homepage": "https://github.com/zaizaizhao/mcp-swagger-server#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.map",
    "README.md",
    "ARCHITECTURE.md",
    "IMPLEMENTATION_SUMMARY.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/figlet": "^1.7.0",
    "axios": "^1.10.0",
    "blessed": "^0.1.81",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.2",
    "conf": "10.0.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "figlet": "^1.8.2",
    "inquirer": "^8.2.6",
    "js-yaml": "^4.1.0",
    "mcp-swagger-parser": "workspace:*",
    "node-persist": "^4.0.4",
    "openapi-types": "^12.1.3",
    "ora": "^5.4.1",
    "tslib": "^2.8.1",
    "uuid": "^10.0.0",
    "zod": "^3.25.28",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.13.0",
    "@types/blessed": "^0.1.25",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/inquirer": "^9.0.9",
    "@types/js-yaml": "^4.0.9",
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.1",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.4",
    "typescript": "^5.8.3"
  }
}
