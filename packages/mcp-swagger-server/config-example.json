{
  "transport": "sse",
  "port": 3325,
  "host": "127.0.0.1",
  "endpoint": "/api/mcp",
  "openapi": "https://petstore.swagger.io/v2/swagger.json",
  "watch": false,
  "allowedHosts": ["localhost", "127.0.0.1"],
  "allowedOrigins": ["http://localhost:3000"],
  "disableDnsRebindingProtection": false,
  "auth": {
    "type": "bearer",
    "bearer": {
      "source": "env",
      "envName": "API_TOKEN"
    }
  },
  "managed": false,
  "autoRestart": true,
  "maxRetries": 3,
  "retryDelay": 2000
}
