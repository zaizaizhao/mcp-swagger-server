NODE_ENV=development
PORT=3001
MCP_PORT=3322

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:3000

# Database mode: sqlite | postgres
# IMPORTANT:
# - sqlite is the default runtime mode
# - PostgreSQL is enabled only when DB_TYPE=postgres is set explicitly
# - DB_HOST / DB_PORT / DB_DATABASE alone do not switch the runtime to PostgreSQL
DB_TYPE=sqlite

# SQLite defaults for single-machine and light-load usage
# Keep DB_TYPE=sqlite, or omit DB_TYPE entirely to stay on the default path.
DB_SQLITE_PATH=data/mcp-swagger.db

# PostgreSQL settings for heavier production deployment
# These settings are read only when DB_TYPE=postgres.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=mcp_swagger_api

# Optional override. In sqlite mode the runtime will default to synchronize=true
# outside production unless this value is set explicitly.
# DB_SYNCHRONIZE=true
DB_LOGGING=false

API_KEY=your-api-key-here
JWT_SECRET=your-jwt-secret-here

SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=Admin@123456
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true

LOG_LEVEL=debug
LOG_FORMAT=pretty
PROCESS_LOG_PERSIST_ENABLED=true
PROCESS_LOG_PERSIST_MIN_INTERVAL_MS=1000
PROCESS_LOG_MAX_MESSAGE_LENGTH=4000
PROCESS_LOG_RETENTION_DAYS=7
SYSTEM_LOG_RETENTION_DAYS=14
HEALTH_CHECK_RETENTION_DAYS=7
HEALTH_CHECK_PERSIST_INTERVAL_MS=60000

REQUEST_TIMEOUT=30000
CACHE_TTL=300
MAX_PAYLOAD_SIZE=50mb

THROTTLE_TTL=60
THROTTLE_LIMIT=10

MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=3322
MCP_SERVER_HEALTH_CHECK_INTERVAL=30000

DEFAULT_OPENAPI_BASE_URL=https://api.example.com
MAX_OPENAPI_FILE_SIZE=50mb
OPENAPI_CACHE_TTL=600

METRICS_ENABLED=true
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_TIMEOUT=5000

HOT_RELOAD=true
WATCH_FILES=true
DEBUG_MODE=true
